{
  "expo": {
    "name": "whats_in_my_fridge",
    "slug": "whats_in_my_fridge",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/shared/assets/images/icon.png",
    "scheme": "whatsinmyfridge",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.docook.whatsinmyfridge",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": ["kakaotalk", "kakaokompassauth", "kakaolink"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./src/shared/assets/images/android-icon-foreground.png",
        "backgroundImage": "./src/shared/assets/images/android-icon-background.png",
        "monochromeImage": "./src/shared/assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.chun4582.whats_in_my_fridge"
    },
    "web": {
      "output": "static",
      "favicon": "./src/shared/assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "./src/shared/assets/fonts/Pretendard-Regular.otf",
            "./src/shared/assets/fonts/Pretendard-Medium.otf",
            "./src/shared/assets/fonts/Pretendard-SemiBold.otf",
            "./src/shared/assets/fonts/Pretendard-Bold.otf",
            "./src/shared/assets/fonts/Pretendard-ExtraBold.otf"
          ]
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./src/shared/assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      [
        "@react-native-seoul/kakao-login",
        {
          "kakaoAppKey": "4962f3c786c5d3dedbae6752bb419662",
          "kotlinVersion": "2.0.0"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dbcdd81f-603a-4fc7-b938-48a16887301d"
      }
    }
  }
}
